from functools import reduce

names = ["ali","rahul","dilshad"]

clean_names = [name.title() for name in names]

numbers = [-10,5,-3,20,30]

valid_numbers = list(filter(lambda x:x>0, numbers))

total = reduce(lambda x,y:x+y, valid_numbers)

print("Clean Names:", clean_names)
print("Valid Numbers:", valid_numbers)
print("Total:", total)
